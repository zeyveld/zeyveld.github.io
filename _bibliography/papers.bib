@article{strategic_stockout_subs,
  abbr={WiP},
  bibtex_show={true},
  title={Using Stockout Substitutions to Steer Consumer Learning: The Case of Curbside Pickup},
  author={Zeyveld, Andrew},
  abstract={In curbside pickup, an item may sell out before its buyer arrives. If so, the store must choose a substitute on her behalf. Using novel data from a supermarket chain, I show that the store's choice of substitute can influence consumers' learning about brands. If someone encounters a new brand through a stockout substitution, she is more likely to purchase its products in the future than if the substitution had never occurred. This fact motivates a structural model of curbside pickup with consumer learning, which I use to characterize the optimal substitution policy under a range of store objectives.},
  journal={Work in Progress,},
  year={2024},
}

@article{identify_demand_orders_and_subs,
  abbr={WiP},
  bibtex_show={true},
  title={Preferences over Unpurchased Goods in Differentiated Products Demand Systems},
  author={Zeyveld, Andrew},
  abstract={Data on consumers' preferences over unpurchased products can help to identify demand elasticities. In this paper, I show  that workhorse discrete choice models exhibit *independence of preferred alternatives* (IPA) properties: a consumer's purchase must be independent of her pairwise preferences among unpurchased products, conditional on their representative utilities. I test the IPA properties of conditional and mixed logit using novel data from curbside pickup. Having identified substitution patterns in the data that are inconsistent with both models' IPA properties, I compare mixed logit's goodness of fit to that of mixed probit, a model that does not display an IPA property.},
  journal={Work in Progress,},
  year={2024},
}

@article{contex_dep_choice,
  abbr={WiP},
  bibtex_show={true},
  title={Choice-Set-Dependent Preferences in Grocery Purchases},
  author={Conlin, M. and Harris-Lagoudakis, K. and Zeyveld, A.},
  journal={Work in Progress,},
  abstract={(One-Sentence Summary) We utilize grocery scanner data to examine how the attributes of unchosen alternatives in a category (e.g., eggs) alter a person’s relative preference amongst products in that category.},
  year={2024},
}




