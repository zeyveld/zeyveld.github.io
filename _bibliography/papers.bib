@article{strategic_stockout_subs,
  abbr={WiP},
  bibtex_show={true},
  title={Using Stockout Substitutions to Steer Consumer Learning: An Empirical Case Study},
  author={Zeyveld, Andrew},
  abstract={In online shopping, the retailer must suggest---or even choose---a substitute if an ordered item goes out of stock. This paper investigates whether the retailer's choice of substitute enables it to manipulate consumer learning. Using novel data from curbside grocery pickup, I find evidence in the affirmative. If the retailer selects a substitute whose brand the consumer has never purchased before, then she is likelier to order that brand in the future than if the stockout never occurred. To quantity the influence of order substitutions on consumer surplus and retailer profits, I estimate a structural model of curbside grocery pickup under consumer learning. Then I use the model's primitives to characterize the optimal substitution policy under a range of retailer objectives.},
  journal={Work in Progress,},
  year={2023},
}

@article{identify_demand_orders_and_subs,
  abbr={WiP},
  bibtex_show={true},
  title={Alternate-Choice Data and the Estimation of Differentiated Products Demand},
  author={Zeyveld, Andrew},
  abstract={``Alternate-choice data,'' which characterize consumers' preferences over products they did not purchase, can help to identify demand elasticities. In this paper, I show that prevailing models of differentiated-products demand impose a form of conditional independence between (i) the consumer's purchase choice and (ii) her relative preferences among the unpurchased goods. Then I proceed to test this conditional independence constraint using novel data from stockout substitutions in curbside grocery pickup. The results suggest that the constraint suffered by conditional logit is not with consumers' choices in any of the differentiated products markets studied, whereas the (less-restrictive) constraint exhibited by mixed logit is consistent with consumers' choices in some---but not all---markets.},
  journal={Work in Progress,},
  year={2023},
}

