@article{strategic_stockout_subs,
  abbr={JMP},
  bibtex_show={true},
  title={Steering Consumers' Learning: Evidence from Stockout Substitutions in Curbside Pickup},
  author={Zeyveld, Andrew},
  abstract={Items ordered for curbside pickup sometimes go out of stock. This obliges the store to choose substitutes on the affected consumers' behalf. Using novel data from a supermarket chain, I show that the store's choice of substitute can influence consumers' future purchases through the mechanism of learning. This presents an opportunity for the store: it can exploit stockout substitutions to introduce consumers to profitable brands. However, consumers are less likely to accept substitutes whose brands are unfamiliar to them. To quantify the trade-off between steering consumers' learning and maximizing the probability of substitutes' being accepted, I estimate a learning-based model of differentiated products demand. Counterfactual simulations suggest that the profitability of steering consumers' learning depends on the amount of learning within the relevant product category, as well as on individual consumers' past purchase histories.},
  journal={Work in Progress,},
  year={2024},
}

@article{identify_demand_orders_and_subs,
  abbr={WP},
  bibtex_show={true},
  title={Preferences among Unpurchased Goods in Differentiated Products Demand Systems},
  author={Zeyveld, Andrew},
  abstract={Data on consumers' preferences among unpurchased products can help identify demand elasticities. However, workhorse demand systems sometimes fail to replicate important substitution patterns in these data. I consider the following explanation for this shortcoming: both conditional and mixed logit impose a form of independence between consumers' purchases and their preferences among unpurchased goods. Using data on curbside grocery pickup, I document substitution patterns that are inconsistent with both models' independence properties. To quantify the influence of the independence property exhibited by mixed logit, I compare the model's goodness of fit to that of mixed probit (which exhibits no such property).},
  journal={Working Paper,},
  year={2024},
  pdf={unpurchased-goods.pdf},
}

