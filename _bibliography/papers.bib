@article{strategic_stockout_subs,
  abbr={WiP},
  bibtex_show={true},
  title={Strategic Stockout Substitutions: Leveraging Consumer Learning to Maximize Profits},
  author={Zeyveld, Andrew},
  abstract={In curbside grocery pickup, an item may sell out before its buyer arrives. When this happens, the store selects a similar product to serve as a substitute. This allows the store to introduce high-margin brands to patrons who usually buy smaller-margin ones—provided they are willing to accept the high-margin brand as a substitute. In this paper, I present reduced-form evidence of stockout substitutions’ influence on shoppers’ later purchases. This motivates a structural learning model of curbside orders and stockout substitutions under uncertain brand quality. The model suggests that strategic substitutions could increase profits by [number] percent.},
  journal={Work in Progress,},
  year={2023},
}

@article{identify_demand_orders_and_subs,
  abbr={WiP},
  bibtex_show={true},
  title={Demand Estimation with Online Orders and Stockout Substitutions: An Application to Curbside Grocery Pickup},
  author={Zeyveld, Andrew},
  abstract={When a shopper orders groceries for curbside pickup, sometimes a requested item goes out of stock before she arrives at the store. This paper asks how her willingness to accept a substitute can help to identify demand. Here, however, workhorse econometric models impose an unrealistic restriction: independence between the shopper’s initial order and her subsequent acceptance or rejection of the substitute. Using data from a regional hypermarket chain, I show that this constraint is incompatible with shoppers’ observed choices and then propose a model relaxing it. Having compared the proposed model’s predictive power to prevailing alternatives, I compute price elasticities which incorporate the additional variation from shoppers’ decisions about stockout substitutes. },
  journal={Work in Progress,},
  year={2023},
}

