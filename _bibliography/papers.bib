@article{state_dependence,
  abbr={WiP},
  bibtex_show={true},
  title={Structural State Dependence or Unobserved Heterogeneity? New Evidence from Stockout Substitutions},
  author={Zeyveld, Andrew},
  abstract={Consumers tend to purchase products they have bought before. When modeling demand, the econometrician typically attributes this repetition to preference heterogeneity. But structural state dependence could also be involved. To determine if this is the case, I study curbside grocery pickup, a setting which supplies exogenous purchase variation in the form of (store-selected) stockout substitutions. Using nonparametric demand estimation, as well as simple tests of equality, I find strong evidence of structural state dependence.  Following a stockout substitution, shoppers are more than ten percentage points likelier to purchase the substitute than if stockout had never occurred.},
  journal={Work in Progress,},
  year={2022},
}

@article{optimal_subs,
  abbr={WiP},
  bibtex_show={true},
  title={Within-Consumer Preference Variation: Clues from Curbside Grocery Pickup},
  author={Zeyveld, Andrew},
  abstract={Demand systems traditionally attribute within-consumer preference variation to i.i.d. errors. But this paper studies a setting where this presumption is inappropriate: stockout substitutions in curbside grocery pickup. When an item ordered for pickup goes out of stock, the store offers a similar one as a replacement. This paper asks which one the shopper would be likeliest to accept. Here, however, workhorse econometric models impose an unrealistic restriction: independence between initial orders and the subsequent acceptance (or rejection) of a substitute. Using data from a regional hypermarket chain, I show this constraint is incompatible with observed choices and then propose a model relaxing it. After comparing the proposed model’s predictive power to prevailing alternatives, I compute the additional profits from offering optimal substitutes.},
  journal={Work in Progress,},
  year={2022},
}

