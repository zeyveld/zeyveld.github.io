@article{strategic_stockout_subs,
  abbr={JMP},
  bibtex_show={true},
  title={Steering Consumers' Learning: Evidence from Stockout Substitutions in Curbside Pickup},
  author={Zeyveld, Andrew},
  abstract={Items ordered for curbside pickup sometimes go out of stock. This obliges the store to choose substitutes on the affected consumers' behalf. Using novel data from a supermarket chain, I show that these ``stockout substitutions'' influence consumers' future purchases through the mechanism of learning. This presents an opportunity for the store. It can increase its future profits by selecting substitutes from profitable brands that the consumers have never tried before. However, I find that consumers are less likely to accept such substitutes than they are to accept substitutes whose brands are more familiar. To quantify the trade-off between steering consumers' learning and maximizing the probability of substitutes' being accepted, I estimate a learning-based model of differentiated products demand. Counterfactual simulations suggest that the profitability of steering consumers' learning depends on the amount of learning within the relevant product category, as well as on individual consumers' purchase histories.},
  journal={Working Paper,},
  year={2024},
  pdf={Zeyveld-JMP.pdf},
}

@article{identify_demand_orders_and_subs,
  abbr={WP},
  bibtex_show={true},
  title={Demand Estimation When Consumers' Preferences Vary over Time},
  author={Zeyveld, Andrew},
  abstract={This paper shows that workhorse demand systems fail to reproduce important substitution patterns when individual consumers' preferences vary over time. The reason is that conditional and mixed logit impose a form of independence between consumers' purchases and their preferences among unpurchased goods. Using novel data on curbside grocery pickup, I document substitution patterns that are inconsistent with conditional logit's independence property. As for mixed logit, the substitution patterns in some---but not all---product categories prove consistent with the model's independence property. To quantify the influence of the independence property exhibited by mixed logit, I compare the model's goodness of fit with that of mixed probit, which exhibits no such property. In keeping with the descriptive evidence, the results of this comparison vary by product category.},
  journal={Working Paper,},
  year={2024},
  pdf={preference-variation.pdf},
}

